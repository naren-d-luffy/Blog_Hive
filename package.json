{
  "name": "blog-back",
  "version": "1.0.0",
  "description": "A high-performance backend for a blog system using Express, TypeScript, and Redis.",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "worker:blog": "ts-node src/queues/workers/blog.worker.ts",
    "worker:email": "ts-node src/queues/workers/email.worker.ts",
    "worker:log": "ts-node src/queues/workers/log.worker.ts",
    "worker": "concurrently \"npm run worker:blog\" \"npm run worker:email\" \"npm run worker:log\""
  },
  "keywords": [
    "blog",
    "backend",
    "express",
    "typescript",
    "bullmq",
    "redis",
    "pino-logging",
    "mongoose"
  ],
  "author": "RamNaren",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/naren-d-luffy/Blog_Back.git"
  },
  "bugs": {
    "url": "https://github.com/naren-d-luffy/Blog_Back/issues"
  },
  "homepage": "https://github.com/naren-d-luffy/Blog_Back#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "commonjs",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "bullmq": "^5.77.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "crypto": "^1.0.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.3.1",
    "nodemailer": "^8.0.5",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "redis": "^5.11.0",
    "slugify": "^1.6.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^8.0.0",
    "concurrently": "^9.2.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
